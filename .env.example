# رابط خادم الأتمتة (Playwright) — إلزامي لبناء الإنتاج إن لم يكن لديك reverse proxy لـ /api
# مثال: https://your-automation-service.onrender.com
# VITE_API_URL=

VITE_GOOGLE_DRIVE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_DRIVE_CLIENT_SECRET=your_google_client_secret_here
VITE_GOOGLE_DRIVE_REFRESH_TOKEN=your_google_refresh_token_here

# انسخ هذا الملف إلى:
# .env.local
# وعدّل القيم أعلاه بالقيم الحقيقية من Google Cloud Console

